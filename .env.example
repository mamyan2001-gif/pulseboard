# Copy to .env and adjust (optional). Pulseboard loads .env automatically.
# cp .env.example .env

PORT=5060
HOST=127.0.0.1

# Public base URL (shown in /api/health). Useful behind a reverse proxy.
# PUBLIC_BASE_URL=https://status.example.com

# Optional webhook for down/up alerts (JSON POST).
# ALERT_WEBHOOK=https://hooks.example.com/pulseboard

# Only needed if the UI is hosted on a different origin than the API.
# CORS_ORIGIN=http://127.0.0.1:5175
